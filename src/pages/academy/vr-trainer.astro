      btn.textContent = "引擎音效 ON";
      btn.classList.add("active");
    } else {
      btn.textContent = "引擎音效 OFF";
      btn.classList.remove("active");
      if (engineGain) engineGain.gain.setTargetAtTime(0, audioCtx!.currentTime, 0.1);
      if (hydraulicGain) hydraulicGain.gain.setTargetAtTime(0, audioCtx!.currentTime, 0.1);
    }
  });

  // Speech toggle
  let speechEnabled = false;
  let lastSpokenText = "";
  document.getElementById("_vrSpeech")?.addEventListener("click", () => {
    speechEnabled = !speechEnabled;
    const btn = document.getElementById("_vrSpeech")!;
    btn.textContent = speechEnabled ? "語音教練 ON" : "語音教練 OFF";
    if (speechEnabled) btn.classList.add("active"); else btn.classList.remove("active");
    if (speechEnabled) {
      setInterval(() => {
        if (speechEnabled && aiCoachText !== lastSpokenText) {
          lastSpokenText = aiCoachText;
          const utterance = new SpeechSynthesisUtterance(aiCoachText);
          utterance.lang = "zh-TW";
          utterance.rate = 1.1;
          speechSynthesis.speak(utterance);
        }
      }, 5000);
    }
  });

  // Init 3D
  const canvas = document.getElementById("_vrCanvas") as HTMLCanvasElement;
  if (canvas) initScene(canvas);
}

/* ═══════════════════════════════════════════════
   STATS RENDERER
   ═══════════════════════════════════════════════ */
function renderStats() {
  const el = document.getElementById("_vrStats");
  if (!el) return;

  const totalSessions = trainingRecords.length;
  const totalTime = trainingRecords.reduce((s, r) => s + r.timeSeconds, 0);
  const passedCount = taskPassed.filter(Boolean).length;
  const avgScore = totalSessions > 0
    ? Math.round(trainingRecords.reduce((s, r) => s + r.bestScore, 0) / totalSessions)
    : 0;

  el.innerHTML = `
    <div class="vr-stats-row"><span>完成關卡</span><span class="vr-stats-val">${passedCount} / ${TASKS.length}</span></div>
    <div class="vr-stats-row"><span>訓練次數</span><span class="vr-stats-val">${totalSessions} 次</span></div>
    <div class="vr-stats-row"><span>總訓練時間</span><span class="vr-stats-val">${Math.floor(totalTime / 60)} 分 ${totalTime % 60} 秒</span></div>
    <div class="vr-stats-row"><span>平均最高分</span><span class="vr-stats-val">${avgScore}</span></div>
  `;
}

/* ═══════════════════════════════════════════════
   KEYBOARD + GAMEPAD EVENTS
   ═══════════════════════════════════════════════ */
document.addEventListener("keydown", e => { keys[e.key] = true; });
document.addEventListener("keyup", e => { keys[e.key] = false; });
window.addEventListener("gamepadconnected", (e) => {
  gamepadIndex = (e as GamepadEvent).gamepad.index;
  aiCoachText = `搖桿已連接：${(e as GamepadEvent).gamepad.id.slice(0, 30)}。左搖桿=旋轉+大臂，右搖桿=小臂+鏟斗。`;
});
window.addEventListener("gamepaddisconnected", () => { gamepadIndex = null; });

/* ═══════════════════════════════════════════════
   ENTRY
   ═══════════════════════════════════════════════ */
document.addEventListener("DOMContentLoaded", () => {
  const container = document.getElementById("vr-container");
  if (container) buildUI(container);
});
</script>
