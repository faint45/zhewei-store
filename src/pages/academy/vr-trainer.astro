  document.querySelectorAll(".vr-task-btn[data-task]").forEach(btn => {
    btn.addEventListener("click", () => {
      const idx = parseInt((btn as HTMLElement).dataset.task || "0");
      if (!taskUnlocked[idx]) return;
      switchTask(idx);
    });
  });

  // Render training stats
  renderStats();

  // WebXR button
  const xrBtn = document.getElementById("_vrXRBtn") as HTMLButtonElement;
  if (navigator.xr) {
    navigator.xr.isSessionSupported("immersive-vr").then(supported => {
      xrBtn.disabled = !supported;
      if (!supported) xrBtn.textContent = "VR 不支援此裝置";
    });
    xrBtn.addEventListener("click", async () => {
      try {
        const session = await navigator.xr!.requestSession("immersive-vr", {
          optionalFeatures: ["local-floor", "bounded-floor"],
        });
        renderer.xr.setSession(session);
        xrBtn.textContent = "VR 模式運行中";
