---
import BaseLayout from "../../layouts/BaseLayout.astro";

const parts = [
  { name: "駕駛室", desc: "操作員控制中心，含操縱桿、儀表板、安全帶。" },
  { name: "大臂 (Boom)", desc: "連接機體與小臂的主要結構件，控制挖掘深度與高度。液壓缸驅動。" },
  { name: "小臂 (Stick/Arm)", desc: "連接大臂與鏟斗，控制挖掘距離。精確控制靠小臂液壓缸。" },
  { name: "鏟斗 (Bucket)", desc: "挖掘和裝載的末端工具。不同工況用不同鏟斗（標準/岩石/清溝）。" },
  { name: "履帶底盤", desc: "提供穩定性和移動能力。橡膠履帶適用泥地，鋼履帶適用岩石。" },
  { name: "回轉平台", desc: "支撐上部結構 360° 旋轉。回轉馬達+齒圈驅動。" },
  { name: "液壓系統", desc: "驅動所有運動部件。主泵+多路閥+液壓缸，工作壓力約 350 bar。" },
  { name: "配重塊", desc: "平衡挖掘力矩，防止機器前傾。通常為鑄鐵，重量 3-8 噸。" },
];

const safetyRules = [
  "操作前檢查液壓系統是否有洩漏",
  "確認回轉範圍內無人員",
  "挖掘深度不超過機具最大挖掘深度的 80%",
  "斜坡作業時保持履帶縱向朝上坡方向",
  "雷雨天氣停止作業並遠離機具",
  "夜間作業需開啟所有照明設備",
];
---

<BaseLayout
  title="挖土機課程"
  description="挖土機操作完整課程 — 3D 零件拆解、操作技巧、安全規範。築未工程學院。"
>
  <section class="px-4 py-10">
    <div class="mx-auto max-w-5xl">
      <!-- Header -->
      <div class="mb-8 flex items-start justify-between">
        <div>
          <a href="/academy" class="mb-2 inline-flex items-center gap-1 text-sm text-text-muted hover:text-accent">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
            返回學院
          </a>
          <h1 class="text-3xl font-black">挖土機操作課程</h1>
          <p class="mt-2 text-text-muted">從零件認識到實際操作，AI 教練全程指導。</p>
        </div>
        <a href="/academy/vr-trainer" class="rounded-xl bg-accent px-6 py-3 font-semibold text-white shadow-lg shadow-accent/25 hover:bg-accent-hover transition-colors">
          開始 VR 訓練
        </a>
      </div>

      <!-- 3D Interactive Exploded View -->
      <div class="mb-10 rounded-2xl border border-border bg-bg-card overflow-hidden">
        <div class="border-b border-border px-4 py-3 flex items-center justify-between">
          <h2 class="text-sm font-bold text-text-heading">3D 互動拆解</h2>
          <span class="text-xs text-text-muted">點擊零件查看說明 · 滑鼠旋轉模型</span>
        </div>
        <div id="explode-container" style="height:400px" class="relative">
          <div id="explode-loading" class="flex items-center justify-center" style="height:400px">
            <div class="text-center">
              <div class="mb-3 h-8 w-8 animate-spin rounded-full border-2 border-border border-t-accent mx-auto"></div>
              <p class="text-xs text-text-muted">載入 3D 模型中…</p>
            </div>
          </div>
        </div>
        <div id="part-info" class="border-t border-border px-4 py-3 text-sm text-text-muted min-h-[48px]">
          點擊零件查看詳細說明
        </div>
      </div>

      <!-- Parts Table -->
      <div class="mb-10">
        <h2 class="mb-4 text-xl font-bold text-text-heading">零件功能一覽</h2>
        <div class="grid gap-3 md:grid-cols-2">
          {parts.map((part, i) => (
            <div class="rounded-xl border border-border bg-bg-card p-4 hover:border-accent/30 transition-colors">
              <div class="flex items-start gap-3">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-accent/10 text-xs font-bold text-accent">{i + 1}</span>
                <div>
                  <div class="font-semibold text-text-heading">{part.name}</div>
                  <p class="mt-1 text-sm text-text-muted">{part.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Safety Rules -->
      <div class="mb-10">
        <h2 class="mb-4 text-xl font-bold text-text-heading">安全操作規範</h2>
        <div class="rounded-2xl border border-border bg-bg-card p-6">
          <ul class="space-y-3">
            {safetyRules.map((rule) => (
              <li class="flex items-start gap-3 text-sm">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
                <span class="text-text-muted">{rule}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center">
        <a href="/academy/vr-trainer" class="inline-flex items-center gap-2 rounded-xl bg-accent px-8 py-3 font-semibold text-white shadow-lg shadow-accent/25 hover:bg-accent-hover transition-colors">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.5 6h-17A1.5 1.5 0 002 7.5v9A1.5 1.5 0 003.5 18h4.22a1.5 1.5 0 001.34-.83L10.5 14h3l1.44 3.17a1.5 1.5 0 001.34.83h4.22a1.5 1.5 0 001.5-1.5v-9A1.5 1.5 0 0020.5 6zM8 13a2 2 0 110-4 2 2 0 010 4zm8 0a2 2 0 110-4 2 2 0 010 4z"/></svg>
          開始 VR 訓練
        </a>
        <p class="mt-3 text-sm text-text-muted">支援手機、電腦、Meta Quest 頭顯</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
import * as THREE from "three";
import { OrbitControls } from "three/addons/controls/OrbitControls.js";

const PARTS_DATA = [
  { name: "駕駛室", color: 0xf4a027, pos: [0.4, 2.2, 0], size: [1.3, 1, 1.5], explodeOffset: [0, 2, 0] },
  { name: "大臂 (Boom)", color: 0xf4a027, pos: [2.5, 3.5, 0], size: [0.4, 3.8, 0.4], explodeOffset: [3, 1, 0] },
  { name: "小臂 (Stick)", color: 0xf4a027, pos: [3.5, 5.5, 0], size: [0.3, 3, 0.3], explodeOffset: [5, 2, 0] },
  { name: "鏟斗 (Bucket)", color: 0x555555, pos: [4, 7, 0], size: [1.3, 0.7, 1.1], explodeOffset: [6, 3, 0] },
  { name: "履帶底盤", color: 0x222222, pos: [0, 0.3, 0], size: [3.8, 0.5, 2.8], explodeOffset: [0, -2, 0] },
  { name: "回轉平台", color: 0x555555, pos: [0, 0.65, 0], size: [2.4, 0.15, 2.4], explodeOffset: [0, -0.5, 0] },
  { name: "機體", color: 0xf4a027, pos: [0, 1.3, 0], size: [2.6, 1.2, 2.1], explodeOffset: [0, 0.5, 0] },
  { name: "配重塊", color: 0x333333, pos: [-1.8, 1.1, 0], size: [0.6, 0.8, 2.2], explodeOffset: [-3, 0, 0] },
];

let exploded = false;
const meshes: THREE.Mesh[] = [];
const origPositions: THREE.Vector3[] = [];

document.addEventListener("DOMContentLoaded", () => {
  const container = document.getElementById("explode-container");
  if (!container) return;

  const loading = document.getElementById("explode-loading");
  const canvas = document.createElement("canvas");
  canvas.style.cssText = "width:100%;height:100%;display:block;";
  container.appendChild(canvas);
  if (loading) loading.style.display = "none";

  const W = container.clientWidth, H = 400;
  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
  renderer.setSize(W, H);
  renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
  renderer.setClearColor(0x111820);

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(45, W / H, 0.1, 100);
  camera.position.set(-6, 5, 8);

  const controls = new OrbitControls(camera, canvas);
  controls.enableDamping = true;
  controls.target.set(1, 2, 0);

  scene.add(new THREE.AmbientLight(0x889aaa, 2));
  const sun = new THREE.DirectionalLight(0xfff5dd, 3);
  sun.position.set(10, 20, 10); scene.add(sun);
  scene.add(new THREE.HemisphereLight(0x87ceeb, 0x362a1a, 0.8));

  // Build parts
  PARTS_DATA.forEach((part, i) => {
    const geo = part.name.includes("平台")
      ? new THREE.CylinderGeometry(1.2, 1.2, 0.15, 24)
      : new THREE.BoxGeometry(...(part.size as [number, number, number]));
    const meshMat = new THREE.MeshStandardMaterial({
      color: part.color, roughness: 0.6, metalness: 0.2,
    });
    const mesh = new THREE.Mesh(geo, meshMat);
    mesh.position.set(...(part.pos as [number, number, number]));
    mesh.name = part.name;
    mesh.userData = { index: i, origColor: part.color };
    scene.add(mesh);
    meshes.push(mesh);
    origPositions.push(mesh.position.clone());
  });

  // Ground
  const ground = new THREE.Mesh(
    new THREE.PlaneGeometry(20, 20), new THREE.MeshLambertMaterial({ color: 0x1a2332 })
  );
  ground.rotation.x = -Math.PI / 2; scene.add(ground);
  scene.add(new THREE.GridHelper(20, 20, 0x243040, 0x1a2332));

  // Raycaster for clicking parts
  const rc = new THREE.Raycaster(), mouse = new THREE.Vector2();
  let hovered: THREE.Mesh | null = null;

  canvas.addEventListener("mousemove", (e) => {
    const rect = canvas.getBoundingClientRect();
    mouse.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
    mouse.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;
    rc.setFromCamera(mouse, camera);
    const hits = rc.intersectObjects(meshes);

    // Reset hover
    if (hovered) {
      (hovered.material as THREE.MeshStandardMaterial).emissive.setHex(0x000000);
      hovered = null;
    }
    if (hits.length > 0) {
      hovered = hits[0].object as THREE.Mesh;
      (hovered.material as THREE.MeshStandardMaterial).emissive.setHex(0x332200);
      canvas.style.cursor = "pointer";
    } else {
      canvas.style.cursor = "default";
    }
  });

  canvas.addEventListener("click", () => {
    if (hovered) {
      const idx = hovered.userData.index;
      const part = PARTS_DATA[idx];
      const descs: Record<string, string> = {
        "駕駛室": "操作員控制中心，含操縱桿、儀表板、安全帶。ROPS/FOPS 保護結構防翻/落物。",
        "大臂 (Boom)": "連接機體與小臂的主要結構件，控制挖掘深度與高度。液壓缸驅動，最大挖掘力 15-25 噸級。",
        "小臂 (Stick)": "連接大臂與鏟斗，控制挖掘距離。精確控制靠小臂液壓缸。",
        "鏟斗 (Bucket)": "挖掘和裝載的末端工具。標準斗/岩石斗/清溝斗。鬥齒可更換。",
        "履帶底盤": "提供穩定性和移動能力。橡膠履帶(泥地)/鋼履帶(岩石)。接地壓力 0.3-0.6 kgf/cm2。",
        "回轉平台": "支撐上部結構 360° 旋轉。回轉馬達+齒圈驅動。需注意回轉半徑安全。",
        "機體": "容納引擎、液壓泵、散熱系統。柴油引擎 100-400 HP。",
        "配重塊": "平衡挖掘力矩，防止機器前傾。鑄鐵材質，3-8 噸。",
      };
      const info = document.getElementById("part-info");
      if (info) info.innerHTML = `<span class="text-accent font-bold">${part.name}</span> — ${descs[part.name] || part.name}`;

      // Highlight selected
      meshes.forEach(m => (m.material as THREE.MeshStandardMaterial).emissive.setHex(0x000000));
      (hovered.material as THREE.MeshStandardMaterial).emissive.setHex(0x442200);
    }
  });

  // Double-click to toggle exploded view
  canvas.addEventListener("dblclick", () => {
    exploded = !exploded;
    meshes.forEach((mesh, i) => {
      const target = exploded
        ? origPositions[i].clone().add(new THREE.Vector3(...(PARTS_DATA[i].explodeOffset as [number, number, number])))
        : origPositions[i];
      // Simple animation
      const start = mesh.position.clone();
      const startTime = performance.now();
      function anim() {
        const t = Math.min((performance.now() - startTime) / 500, 1);
        const ease = t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
        mesh.position.lerpVectors(start, target, ease);
        if (t < 1) requestAnimationFrame(anim);
      }
      anim();
    });
  });

  // Render loop
  function animate() {
    requestAnimationFrame(animate);
    controls.update();
    renderer.render(scene, camera);
  }
  animate();

  new ResizeObserver(() => {
    const w = container.clientWidth;
    renderer.setSize(w, 400, false);
    camera.aspect = w / 400;
    camera.updateProjectionMatrix();
  }).observe(container);
});
</script>
