---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductDetail from "../../components/ProductDetail.astro";
import DemoTerminal from "../../components/DemoTerminal.astro";
import ProductFlow from "../../components/ProductFlow.astro";
import { products } from "../../content/products";

const product = products.find((p) => p.id === "site-ai")!;

const requestBody = `{
  "project_id": "proj-2026-001",
  "image_url": "https://example.com/site_photo_0407.jpg",
  "location": "3F 東側外牆模板"
}`;

const responseJson = `{
  "record_id": "rec-20260407-083421",
  "timestamp": "2026-04-07T08:34:21+08:00",
  "category": "施工進度",
  "ai_analysis": {
    "status": "in_progress",
    "progress_percent": 68,
    "observations": [
      "3F 東側模板組立完成約 70%",
      "鋼筋綁紮已完成，待澆置混凝土",
      "模板支撐系統外觀正常"
    ],
    "issues": [],
    "safety_flags": []
  },
  "structured_record": {
    "work_item": "3F RC 牆模板",
    "worker_count": 6,
    "equipment": ["模板支撐", "綁鋼筋工具"],
    "weather": "晴，28°C"
  },
  "auto_tags": ["#模板", "#3F", "#RC牆", "#進度正常"]
}`;

const flow = [
  { icon: "M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z M15 13a3 3 0 11-6 0 3 3 0 016 0z", label: "拍照", sublabel: "手機 / LINE", color: "from-green-500 to-emerald-400" },
  { icon: "M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-3 3v-3z", label: "n8n 路由", sublabel: "LINE Webhook", color: "from-blue-500 to-indigo-400" },
  { icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z", label: "AI 分析", sublabel: "Qwen3 視覺", color: "from-purple-500 to-violet-400" },
  { icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z", label: "自動歸檔", sublabel: "Qdrant 向量庫", color: "from-orange-500 to-amber-400" },
];
---

<BaseLayout title={product.name} description={product.description}>
  <ProductDetail product={product}>
    <div slot="demo" class="mb-12 space-y-10">
      <!-- Flow -->
      <div>
        <h2 class="mb-4 text-2xl font-bold">工作流程</h2>
        <div class="rounded-2xl border border-border bg-bg-card p-6">
          <ProductFlow steps={flow} flowId="site-detail-flow" />
        </div>
      </div>
      <!-- Terminal -->
      <div>
        <h2 class="mb-4 text-2xl font-bold">互動 Demo — 現場照片分析</h2>
        <p class="mb-5 text-sm text-text-muted">模擬上傳一張工地照片，AI 自動辨識施工狀態並結構化記錄。</p>
        <DemoTerminal
          productId="site-ai"
          method="POST"
          endpoint="/api/v1/site/photo"
          requestBody={requestBody}
          responseJson={responseJson}
          label="分析現場照片"
        />
      </div>
    </div>
  </ProductDetail>
</BaseLayout>
