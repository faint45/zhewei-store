---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="互動工地模擬"
  description="真實衛星地形、16 種營建機具動態作動模擬、路徑繪製、AI 自動排程 — 築未科技互動體驗。"
>
  <section class="px-4 py-10">
    <div class="mx-auto max-w-7xl">
      <div class="mb-8 text-center">
        <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-accent/30 bg-accent/10 px-4 py-1.5 text-sm font-medium text-accent">
          PlanAI × SiteAI — 互動體驗
        </div>
        <h1 class="text-3xl font-black md:text-4xl">3D 工地模擬 + AI 自動排程</h1>
        <p class="mt-3 text-text-muted md:text-lg">
          選擇真實地點、放置機具、繪製作業路徑，AI 即時生成 CPM 排程。
        </p>
      </div>

      <div id="sim-container" class="rounded-2xl border border-border bg-bg-card overflow-hidden" style="min-height:640px">
        <div id="sim-loading" class="flex items-center justify-center" style="min-height:640px">
          <div class="text-center">
            <div class="mb-4 h-10 w-10 animate-spin rounded-full border-2 border-border border-t-accent mx-auto"></div>
            <p class="text-sm text-text-muted">載入 3D 引擎中…</p>
          </div>
        </div>
      </div>

      <div class="mt-8 grid gap-4 sm:grid-cols-4">
        <div class="rounded-xl border border-border bg-bg-card p-4">
          <div class="mb-2 text-accent font-bold">🛰️ 衛星地形</div>
          <p class="text-sm text-text-muted">輸入地址或座標，自動擷取 ESRI 衛星影像 + 真實高程生成 3D 地形。</p>
        </div>
        <div class="rounded-xl border border-border bg-bg-card p-4">
          <div class="mb-2 text-accent font-bold">🚧 16 種機具</div>
          <p class="text-sm text-text-muted">挖掘機、吊車、傾卸卡車、泵車等台灣常見營建機具，高擬真動態作動。</p>
        </div>
        <div class="rounded-xl border border-border bg-bg-card p-4">
          <div class="mb-2 text-accent font-bold">🛤️ 路徑繪製</div>
          <p class="text-sm text-text-muted">在地形上繪製行駛路線或框選作業區域，機具自動沿路徑作動。</p>
        </div>
        <div class="rounded-xl border border-border bg-bg-card p-4">
          <div class="mb-2 text-accent font-bold">⚡ AI CPM 排程</div>
          <p class="text-sm text-text-muted">依據放置機具組合，AI 自動生成施工排程、關鍵路徑與風險提示。</p>
        </div>
      </div>

      <div class="mt-8 flex flex-col items-center gap-4 text-center sm:flex-row sm:justify-center">
        <a href="/demo" class="rounded-xl bg-accent px-8 py-3 font-semibold text-white shadow-lg shadow-accent/25 transition-all hover:bg-accent-hover">
          申請完整試用
        </a>
        <a href="/products/plan-ai" class="rounded-xl border border-border px-8 py-3 font-semibold text-text-heading transition-colors hover:border-accent/50 hover:text-accent">
          了解 PlanAI 詳情
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
import * as THREE from "three";
import { OrbitControls } from "three/addons/controls/OrbitControls.js";
import { GLTFLoader } from "three/addons/loaders/GLTFLoader.js";

/* ═══════════════════════════════════════════════
   EQUIPMENT CATALOG — 16 台灣常見營建機具
   ═══════════════════════════════════════════════ */
interface EquipmentDef {
  id: string; name: string; cat: string; task: string; duration: number;
  color: number; glb?: string; scale?: number; rotY?: number;
  realLen?: number; /* real-world length in meters, for auto-scaling to map */
}
const CATS: Record<string, string> = {
  earth: "土方機具", lift: "吊裝機具", transport: "運輸機具",
  concrete: "混凝土機具", road: "道路工程", safety: "交通安全設施", other: "其他設備",
};
const EQ: EquipmentDef[] = [
  // 土方  (realLen = real-world longest dimension in meters)
  { id:"exc-l", name:"挖掘機(大)", cat:"earth", task:"土方開挖", duration:30, color:0xf4a027, glb:"/models/excavator.glb", realLen:10 },
  { id:"exc-s", name:"挖掘機(小)", cat:"earth", task:"溝渠開挖", duration:20, color:0xe89020, glb:"/models/excavator.glb", realLen:6 },
  { id:"bull",  name:"推土機",     cat:"earth", task:"整地作業", duration:14, color:0xffd700, glb:"/models/bulldozer.glb", realLen:6 },
  { id:"roller",name:"壓路機",     cat:"earth", task:"壓實作業", duration:10, color:0xddbb00, glb:"/models/road-roller.glb", realLen:5 },
  { id:"bobcat",name:"山貓",       cat:"earth", task:"搬運整理", duration:12, color:0xee9922, glb:"/models/forklift.glb", realLen:3.5 },
  // 吊裝
  { id:"crane-t", name:"塔式起重機", cat:"lift", task:"吊裝作業",   duration:90, color:0xffaa00, glb:"/models/crane.glb", realLen:50 },
  { id:"crane-c", name:"履帶吊車",   cat:"lift", task:"重物吊裝",   duration:60, color:0xff8800, glb:"/models/crane-truck.glb", realLen:20 },
  { id:"crane-k", name:"吊卡車",     cat:"lift", task:"一般吊裝",   duration:45, color:0xdd7700, glb:"/models/crane-truck.glb", realLen:12 },
  { id:"elev",    name:"施工電梯",   cat:"lift", task:"垂直運輸",   duration:80, color:0x888888, realLen:30 },
  // 運輸
  { id:"dump",  name:"傾卸卡車", cat:"transport", task:"土方運輸", duration:25, color:0x6688aa, glb:"/models/dump-truck.glb", realLen:8 },
  { id:"flat",  name:"平板貨車", cat:"transport", task:"材料運輸", duration:20, color:0x557799, glb:"/models/flatbed-truck.glb", realLen:10 },
  { id:"led",   name:"LED 警示車", cat:"transport", task:"交通管制", duration:30, color:0xff6600, glb:"/models/led-truck.glb", realLen:8 },
  { id:"crash", name:"緩撞車",     cat:"transport", task:"施工防護", duration:30, color:0xffaa00, glb:"/models/dump-truck.glb", realLen:7 },
  // 混凝土
  { id:"pump",  name:"混凝土泵車",   cat:"concrete", task:"混凝土澆置", duration:60, color:0x2266cc, realLen:12 },
  { id:"mixer", name:"混凝土攪拌車", cat:"concrete", task:"混凝土供應", duration:30, color:0x3377dd, glb:"/models/concrete-mixer.glb", realLen:9 },
  // 道路工程
  { id:"milling", name:"AC刨除機", cat:"road", task:"路面刨除", duration:20, color:0xcc6600, glb:"/models/bulldozer.glb", realLen:7 },
  { id:"paver",   name:"鋪裝機",   cat:"road", task:"瀝青鋪設", duration:25, color:0xdd8800, glb:"/models/paver.glb", realLen:8 },
  { id:"roller2", name:"鋼輪壓路機", cat:"road", task:"路面壓實", duration:15, color:0xccaa00, glb:"/models/road-roller.glb", realLen:5 },
  // 交通安全設施
  { id:"cone",      name:"交通錐",     cat:"safety", task:"交通管制", duration:1, color:0xff6600, glb:"/models/traffic-cone.glb", realLen:0.7 },
  { id:"barrier",   name:"拒馬",       cat:"safety", task:"道路封閉", duration:1, color:0xff4400, glb:"/models/barricade.glb", realLen:1.5 },
  { id:"road-sign", name:"施工告示牌", cat:"safety", task:"施工提醒", duration:1, color:0xff8800, glb:"/models/road-barrier.glb", realLen:1.2 },
  // 其他
  { id:"pile",  name:"打樁機",     cat:"other", task:"基樁施工", duration:45, color:0x888888, realLen:18 },
  { id:"gen",   name:"發電機",     cat:"other", task:"臨時電力", duration:90, color:0x556655, glb:"/models/generator.glb", realLen:2.5 },
  { id:"rebar", name:"鋼筋彎曲機", cat:"other", task:"鋼筋加工", duration:60, color:0x665555, realLen:1.5 },
];

/* ═══════════════════════════════════════════════
   GLOBALS
   ═══════════════════════════════════════════════ */
let _renderer: THREE.WebGLRenderer | null = null;
let _scene: THREE.Scene, _camera: THREE.PerspectiveCamera, _controls: any;
let _terrain: THREE.Mesh | null = null;
let _ghostMesh: THREE.Mesh;
let _terrainHeightFn: (x: number, z: number) => number = terrainY;
// For procedural terrain: 80 units = ~200m (construction site scale)
// For satellite terrain: computed from tile zoom level
let _metersPerUnit = 1.0; // default terrain: 1 world unit ≈ 1 meter (procedural models authored at this scale)
let _selectedEqId: string | null = null;
let _toolMode: "place" | "path" | "area" | "delete" = "place";
let _dragStartX = 0, _dragStartY = 0, _isDragging = false;
let _lastTime = performance.now();
let _animMixers: THREE.AnimationMixer[] = [];

interface PlacedEq {
  mesh: THREE.Group;
  def: EquipmentDef;
  animState: Record<string, number>;
  path?: THREE.Vector3[];
  pathCurve?: THREE.CatmullRomCurve3;
}
let _placed: PlacedEq[] = [];

// Path / Area drawing
let _pathPoints: THREE.Vector3[] = [];
let _pathLine: THREE.Line | null = null;
let _areaPoints: THREE.Vector3[] = [];
let _areaMesh: THREE.Mesh | null = null;
let _drawnPaths: { points: THREE.Vector3[]; line: THREE.Line; curve: THREE.CatmullRomCurve3 }[] = [];
let _drawnAreas: { points: THREE.Vector3[]; mesh: THREE.Mesh }[] = [];

/* ═══════════════════════════════════════════════
   TERRAIN — procedural fallback
   ═══════════════════════════════════════════════ */
function terrainY(x: number, z: number): number {
  return Math.sin(x*0.14)*1.8+Math.cos(z*0.11)*1.3+Math.sin((x+z)*0.07)*2.2+Math.cos(x*0.23)*0.9;
}

/* ═══════════════════════════════════════════════
   TERRAIN — Mapbox/ESRI satellite + AWS elevation
   ═══════════════════════════════════════════════ */
function lngLatToTile(lng: number, lat: number, z: number) {
  const x = Math.floor((lng + 180) / 360 * (1 << z));
  const y = Math.floor((1 - Math.log(Math.tan(lat * Math.PI / 180) + 1 / Math.cos(lat * Math.PI / 180)) / Math.PI) / 2 * (1 << z));
  return { x, y, z };
}

function fetchImg(url: string): Promise<HTMLImageElement> {
  return new Promise((res, rej) => {
    const img = new Image();
    img.crossOrigin = "anonymous";
    img.onload = () => res(img);
    img.onerror = rej;
    img.src = url;
  });
}

async function buildSatelliteTerrain(lng: number, lat: number, zoom = 15): Promise<{ mesh: THREE.Mesh; heightAt: (x: number, z: number) => number }> {
  const t = lngLatToTile(lng, lat, zoom);
  // Calculate real-world tile size in meters (Web Mercator)
  const tileMeters = 40075016.686 * Math.cos(lat * Math.PI / 180) / (1 << zoom);
  _metersPerUnit = tileMeters / 80; // 80 = world size
  // Fetch tiles
  const satUrl = (tx: number, ty: number) => `https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/${t.z}/${ty}/${tx}`;
  const demUrl = (tx: number, ty: number) => `https://s3.amazonaws.com/elevation-tiles-prod/terrarium/${t.z}/${tx}/${ty}.png`;

  const [satImg, demImg] = await Promise.all([
    fetchImg(satUrl(t.x, t.y)),
    fetchImg(demUrl(t.x, t.y)),
  ]);

  // Decode DEM (Terrarium format: height = (R*256 + G + B/256) - 32768)
  const cv = document.createElement("canvas");
  cv.width = demImg.width; cv.height = demImg.height;
  const ctx = cv.getContext("2d")!;
  ctx.drawImage(demImg, 0, 0);
  const pxData = ctx.getImageData(0, 0, cv.width, cv.height).data;
  const w = cv.width, h = cv.height;
  const heights = new Float32Array(w * h);
  let hMin = Infinity, hMax = -Infinity;
  for (let i = 0; i < w * h; i++) {
    const r = pxData[i * 4], g = pxData[i * 4 + 1], b = pxData[i * 4 + 2];
    const elev = (r * 256 + g + b / 256) - 32768;
    heights[i] = elev;
    if (elev < hMin) hMin = elev;
    if (elev > hMax) hMax = elev;
  }

  // Controlled exaggeration: max 6 units of height in 80-unit world
  // This keeps terrain gentle enough that equipment is visible
  const hRange = Math.max(hMax - hMin, 0.1);
  const targetHeight = Math.min(6, hRange * 0.3); // at most 6 world units tall
  const exaggeration = targetHeight / hRange;

  const seg = window.innerWidth < 800 ? 64 : 128;
  const geo = new THREE.PlaneGeometry(80, 80, seg, seg);
  geo.rotateX(-Math.PI / 2);
  const pos = geo.attributes.position;
  const uv = geo.attributes.uv;

  // Bilinear interpolation for smooth terrain (avoid jagged spikes)
  function sampleHeight(u01: number, v01: number): number {
    const fx = u01 * (w - 1), fy = v01 * (h - 1);
    const ix = Math.floor(fx), iy = Math.floor(fy);
    const dx = fx - ix, dy = fy - iy;
    const ix1 = Math.min(ix + 1, w - 1), iy1 = Math.min(iy + 1, h - 1);
    const h00 = heights[iy * w + ix], h10 = heights[iy * w + ix1];
    const h01 = heights[iy1 * w + ix], h11 = heights[iy1 * w + ix1];
    return h00 * (1 - dx) * (1 - dy) + h10 * dx * (1 - dy) + h01 * (1 - dx) * dy + h11 * dx * dy;
  }

  for (let i = 0; i < pos.count; i++) {
    const u = uv.getX(i);
    const v = uv.getY(i);
    const elev = sampleHeight(u, 1 - v); // flip V for image coords
    pos.setY(i, (elev - hMin) * exaggeration);
  }
  geo.computeVertexNormals();

  // Create texture from satellite image — ensure proper UV alignment
  const satCv = document.createElement("canvas");
  satCv.width = satImg.width; satCv.height = satImg.height;
  const satCtx = satCv.getContext("2d")!;
  satCtx.drawImage(satImg, 0, 0);
  const tex = new THREE.CanvasTexture(satCv);
  tex.colorSpace = THREE.SRGBColorSpace;
  tex.wrapS = tex.wrapT = THREE.ClampToEdgeWrapping;
  tex.minFilter = THREE.LinearFilter;
  tex.magFilter = THREE.LinearFilter;

  const mat = new THREE.MeshLambertMaterial({ map: tex });
  const mesh = new THREE.Mesh(geo, mat);
  mesh.receiveShadow = true;

  // Height lookup matching the same bilinear interpolation
  const heightAt = (x: number, z: number): number => {
    const u2 = Math.max(0, Math.min(1, (x + 40) / 80));
    const v2 = Math.max(0, Math.min(1, (z + 40) / 80));
    return (sampleHeight(u2, v2) - hMin) * exaggeration;
  };
  return { mesh, heightAt };
}

/* ═══════════════════════════════════════════════
   GLTF MODEL LOADER
   ═══════════════════════════════════════════════ */
const _gltfLoader = new GLTFLoader();
const _modelCache: Record<string, THREE.Group> = {};

async function loadGLTFModel(url: string): Promise<THREE.Group> {
  if (_modelCache[url]) return _modelCache[url].clone();
  return new Promise((resolve, reject) => {
    _gltfLoader.load(url, (gltf) => {
      const model = gltf.scene;
      model.traverse((child) => {
        if ((child as THREE.Mesh).isMesh) {
          child.castShadow = true;
          child.receiveShadow = true;
        }
      });
      _modelCache[url] = model;
      resolve(model.clone());
    }, undefined, reject);
  });
}

/* ═══════════════════════════════════════════════
   EQUIPMENT MESH BUILDERS — GLTF + 程式碼建模 (PBR)
   ═══════════════════════════════════════════════ */
// PBR material helpers
function mat(c: number, r = 0.7, met = 0.1): THREE.MeshStandardMaterial {
  return new THREE.MeshStandardMaterial({ color: c, roughness: r, metalness: met });
}
function metalMat(c: number): THREE.MeshStandardMaterial {
  return new THREE.MeshStandardMaterial({ color: c, roughness: 0.35, metalness: 0.8 });
}
function glassMat(): THREE.MeshStandardMaterial {
  return new THREE.MeshStandardMaterial({ color: 0x88bbff, roughness: 0.1, metalness: 0.2, transparent: true, opacity: 0.4 });
}
const tireMat = () => mat(0x222222, 0.9, 0.0);
const frameMat = () => metalMat(0x444444);
const hydraulicMat = () => metalMat(0x999999);

function addWheel(parent: THREE.Object3D, x: number, y: number, z: number, radius = 0.45) {
  const tire = new THREE.Mesh(new THREE.CylinderGeometry(radius, radius, 0.35, 16), tireMat());
  tire.rotation.x = Math.PI / 2; tire.position.set(x, y, z); tire.name = "wheel";
  const hub = new THREE.Mesh(new THREE.CylinderGeometry(radius * 0.4, radius * 0.4, 0.36, 8), metalMat(0x888888));
  hub.rotation.x = Math.PI / 2; hub.position.set(x, y, z);
  parent.add(tire); parent.add(hub);
}

function addHydraulicCylinder(parent: THREE.Object3D, from: THREE.Vector3, to: THREE.Vector3) {
  const dir = to.clone().sub(from);
  const len = dir.length();
  const mid = from.clone().add(to).multiplyScalar(0.5);
  const cyl = new THREE.Mesh(new THREE.CylinderGeometry(0.06, 0.08, len, 8), hydraulicMat());
  cyl.position.copy(mid);
  cyl.lookAt(to);
  cyl.rotateX(Math.PI / 2);
  parent.add(cyl);
}

async function buildEquipmentMesh(def: EquipmentDef, px: number, pz: number): Promise<THREE.Group> {
  // Calculate target world-unit size from real-world dimensions
  const realLen = def.realLen || 5; // meters
  const targetWorldUnits = realLen / _metersPerUnit;

  // Use PBR procedural mesh (more realistic than low-poly GLTF)
  // GLTF models disabled — they were cartoon-style and looked fake

  // Fallback: procedural mesh
  const g = new THREE.Group();
  g.name = def.id;

  if (def.id === "exc-l" || def.id === "exc-s") {
    const sc = def.id === "exc-s" ? 0.65 : 1;
    const bodyColor = mat(def.color);
    // Tracks — rounded with drive sprockets
    [-1.15, 1.15].forEach(z => {
      const trackFrame = new THREE.Mesh(new THREE.BoxGeometry(3.8, 0.5, 0.55), frameMat()); trackFrame.position.set(0, 0.3, z * sc); g.add(trackFrame);
      // Track pads (rubber)
      const pad = new THREE.Mesh(new THREE.BoxGeometry(3.8, 0.15, 0.65), tireMat()); pad.position.set(0, 0.08, z * sc); g.add(pad);
      // Drive sprocket front/rear
      [1.7, -1.7].forEach(x => {
        const sprocket = new THREE.Mesh(new THREE.CylinderGeometry(0.28, 0.28, 0.4, 12), metalMat(0x555555));
        sprocket.rotation.x = Math.PI / 2; sprocket.position.set(x, 0.3, z * sc); g.add(sprocket);
      });
      // Idler wheels
      [-0.8, 0, 0.8].forEach(x => {
        const idler = new THREE.Mesh(new THREE.CylinderGeometry(0.18, 0.18, 0.3, 10), metalMat(0x444444));
        idler.rotation.x = Math.PI / 2; idler.position.set(x, 0.12, z * sc); g.add(idler);
      });
    });
    // Turntable
    const turntable = new THREE.Mesh(new THREE.CylinderGeometry(1.2, 1.2, 0.15, 24), metalMat(0x555555));
    turntable.position.y = 0.65; g.add(turntable);
    // Cabin pivot
    const cabinPivot = new THREE.Group(); cabinPivot.name = "cabinPivot"; cabinPivot.position.y = 0.72;
    // Main body
    const body = new THREE.Mesh(new THREE.BoxGeometry(2.6, 1.2, 2.1), bodyColor); body.position.y = 0.6; cabinPivot.add(body);
    // Engine cover (rear rounded)
    const engine = new THREE.Mesh(new THREE.BoxGeometry(1.2, 0.9, 2), bodyColor); engine.position.set(-1.2, 0.5, 0); cabinPivot.add(engine);
    // Exhaust pipe
    const exhaust = new THREE.Mesh(new THREE.CylinderGeometry(0.06, 0.06, 0.6, 8), metalMat(0x333333)); exhaust.position.set(-1.4, 1.3, 0.5); cabinPivot.add(exhaust);
    // Cab with window
    const cab = new THREE.Mesh(new THREE.BoxGeometry(1.3, 1, 1.5), bodyColor); cab.position.set(0.4, 1.5, 0); cabinPivot.add(cab);
    const window1 = new THREE.Mesh(new THREE.PlaneGeometry(1.25, 0.7), glassMat()); window1.position.set(1.06, 1.6, 0); window1.rotation.y = Math.PI / 2; cabinPivot.add(window1);
    const window2 = new THREE.Mesh(new THREE.PlaneGeometry(1.1, 0.7), glassMat()); window2.position.set(0.4, 1.6, 0.76); cabinPivot.add(window2);
    // Counterweight
    const cw = new THREE.Mesh(new THREE.BoxGeometry(0.6, 0.8, 2.2), mat(0x333333, 0.8, 0.3)); cw.position.set(-1.8, 0.4, 0); cabinPivot.add(cw);

    // Boom pivot (articulated arm)
    const boomPivot = new THREE.Group(); boomPivot.name = "boomPivot"; boomPivot.position.set(1.3, 1.1, 0);
    const boom = new THREE.Mesh(new THREE.BoxGeometry(0.4, 3.8, 0.4), bodyColor); boom.position.y = 1.9; boomPivot.add(boom);
    addHydraulicCylinder(boomPivot, new THREE.Vector3(-0.3, 0, 0), new THREE.Vector3(0, 2.5, 0));
    // Stick pivot
    const stickPivot = new THREE.Group(); stickPivot.name = "stickPivot"; stickPivot.position.set(0, 3.8, 0);
    const stick = new THREE.Mesh(new THREE.BoxGeometry(0.3, 3, 0.3), bodyColor); stick.position.y = 1.5; stickPivot.add(stick);
    addHydraulicCylinder(stickPivot, new THREE.Vector3(0.2, 0, 0), new THREE.Vector3(0, 2, 0));
    // Bucket pivot
    const bucketPivot = new THREE.Group(); bucketPivot.name = "bucketPivot"; bucketPivot.position.set(0, 3, 0);
    // Bucket with teeth
    const bucketBody = new THREE.Mesh(new THREE.BoxGeometry(1.3, 0.7, 1.1), metalMat(0x555555)); bucketBody.position.y = 0.35; bucketPivot.add(bucketBody);
    const lip = new THREE.Mesh(new THREE.BoxGeometry(1.3, 0.15, 0.15), metalMat(0x666666)); lip.position.set(0, 0.05, -0.55); bucketPivot.add(lip);
    // Bucket teeth
    [-0.45, -0.15, 0.15, 0.45].forEach(x => {
      const tooth = new THREE.Mesh(new THREE.ConeGeometry(0.06, 0.2, 4), metalMat(0x777777)); tooth.position.set(x, -0.05, -0.6); tooth.rotation.x = Math.PI / 2; bucketPivot.add(tooth);
    });
    stickPivot.add(bucketPivot); boomPivot.add(stickPivot); cabinPivot.add(boomPivot);
    g.add(cabinPivot);
    g.scale.setScalar(sc);

  } else if (def.id === "crane-t") {
    // Tower crane — lattice structure
    const towerMat = mat(def.color, 0.5, 0.3);
    // Base foundation
    const base = new THREE.Mesh(new THREE.BoxGeometry(4, 0.8, 4), mat(0x555555, 0.8, 0.2)); base.position.y = 0.4; g.add(base);
    // Tower legs (4 corner posts)
    [[-0.35, -0.35], [-0.35, 0.35], [0.35, -0.35], [0.35, 0.35]].forEach(([x, z]) => {
      const leg = new THREE.Mesh(new THREE.BoxGeometry(0.15, 18, 0.15), towerMat); leg.position.set(x, 9.8, z); g.add(leg);
    });
    // Lattice bracing
    for (let y = 1; y < 18; y += 2) {
      [0, Math.PI / 2].forEach(rot => {
        const brace = new THREE.Mesh(new THREE.BoxGeometry(0.06, 2.8, 0.06), towerMat);
        brace.position.set(0, y + 1, 0); brace.rotation.y = rot; brace.rotation.z = 0.6; g.add(brace);
        const brace2 = brace.clone(); brace2.rotation.z = -0.6; g.add(brace2);
      });
      // Horizontal crossbar
      const hbar = new THREE.Mesh(new THREE.BoxGeometry(0.9, 0.06, 0.06), towerMat); hbar.position.set(0, y, 0); g.add(hbar);
      const hbar2 = hbar.clone(); hbar2.rotation.y = Math.PI / 2; g.add(hbar2);
    }
    // Slewing unit
    const slew = new THREE.Mesh(new THREE.CylinderGeometry(0.6, 0.6, 0.4, 16), metalMat(0x555555)); slew.position.y = 18.8; g.add(slew);
    // Boom group (rotates)
    const boomG = new THREE.Group(); boomG.name = "boomGroup"; boomG.position.y = 19;
    // Jib arm (lattice)
    const jibLen = 16;
    [0.15, -0.15].forEach(z => { const rail = new THREE.Mesh(new THREE.BoxGeometry(jibLen, 0.1, 0.1), towerMat); rail.position.set(-jibLen / 2 + 4, 0.15, z); boomG.add(rail); });
    const bottomRail = new THREE.Mesh(new THREE.BoxGeometry(jibLen, 0.1, 0.4), towerMat); bottomRail.position.set(-jibLen / 2 + 4, -0.15, 0); boomG.add(bottomRail);
    // Jib cross bracing
    for (let x = -jibLen + 5; x < 5; x += 1.5) {
      const vb = new THREE.Mesh(new THREE.BoxGeometry(0.05, 0.3, 0.3), towerMat); vb.position.set(x, 0, 0); boomG.add(vb);
    }
    // Counter jib
    const cjib = new THREE.Mesh(new THREE.BoxGeometry(5, 0.3, 0.3), towerMat); cjib.position.set(5, 0, 0); boomG.add(cjib);
    // Counterweights
    const cwt = new THREE.Mesh(new THREE.BoxGeometry(1.5, 1, 1), mat(0x444444, 0.8, 0.3)); cwt.position.set(6.5, -0.3, 0); boomG.add(cwt);
    // Cat head / peak
    const peak = new THREE.Mesh(new THREE.BoxGeometry(0.15, 2, 0.15), towerMat); peak.position.set(0, 1.2, 0); boomG.add(peak);
    // Pendant cables (top to jib tip)
    const cableMat = metalMat(0xaaaaaa);
    const pendantGeo = new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(0, 2.2, 0), new THREE.Vector3(-jibLen + 4, 0.3, 0)]);
    boomG.add(new THREE.Line(pendantGeo, new THREE.LineBasicMaterial({ color: 0x888888 })));
    const pendantGeo2 = new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(0, 2.2, 0), new THREE.Vector3(7, 0.3, 0)]);
    boomG.add(new THREE.Line(pendantGeo2, new THREE.LineBasicMaterial({ color: 0x888888 })));
    // Trolley
    const trolley = new THREE.Mesh(new THREE.BoxGeometry(0.5, 0.2, 0.35), metalMat(0x666666)); trolley.position.set(-8, -0.1, 0); trolley.name = "trolley"; boomG.add(trolley);
    // Cable + hook
    const cable = new THREE.Mesh(new THREE.CylinderGeometry(0.025, 0.025, 8, 6), cableMat); cable.position.set(-8, -4.1, 0); cable.name = "cable"; boomG.add(cable);
    const hookBlock = new THREE.Mesh(new THREE.BoxGeometry(0.3, 0.4, 0.3), metalMat(0x888888)); hookBlock.position.set(-8, -8, 0); hookBlock.name = "hook"; boomG.add(hookBlock);
    const hookCurve = new THREE.Mesh(new THREE.TorusGeometry(0.15, 0.04, 8, 12, Math.PI), metalMat(0xaaaaaa)); hookCurve.position.set(-8, -8.3, 0); boomG.add(hookCurve);
    // Operator cab
    const opCab = new THREE.Mesh(new THREE.BoxGeometry(0.8, 0.8, 0.7), mat(def.color, 0.6, 0.1)); opCab.position.set(0.8, -0.2, 0); boomG.add(opCab);
    const opWin = new THREE.Mesh(new THREE.PlaneGeometry(0.75, 0.5), glassMat()); opWin.position.set(0.8, -0.1, 0.36); boomG.add(opWin);
    g.add(boomG);

  } else if (def.id === "crane-c") {
    // Crawler crane
    [-1.3, 1.3].forEach(z => { const t = new THREE.Mesh(new THREE.BoxGeometry(4, 0.8, 1.2), dark); t.position.set(0, 0.4, z); g.add(t); });
    const cabinPivot = new THREE.Group(); cabinPivot.name = "cabinPivot";
    const body = new THREE.Mesh(new THREE.BoxGeometry(3, 2, 2.4), m(def.color)); body.position.y = 1.8; cabinPivot.add(body);
    const boomPivot = new THREE.Group(); boomPivot.name = "boomPivot"; boomPivot.position.set(1, 2.5, 0);
    const boom = new THREE.Mesh(new THREE.BoxGeometry(0.5, 12, 0.5), m(def.color)); boom.position.y = 6; boomPivot.add(boom);
    const hookG = new THREE.Group(); hookG.name = "hookGroup"; hookG.position.set(0, 12, 0);
    const cable = new THREE.Mesh(new THREE.CylinderGeometry(0.04, 0.04, 6, 6), grey); cable.position.y = -3; hookG.add(cable);
    const hook = new THREE.Mesh(new THREE.BoxGeometry(0.6, 0.6, 0.6), m(0xaaaaaa)); hook.position.y = -6; hook.name = "hook"; hookG.add(hook);
    boomPivot.add(hookG); cabinPivot.add(boomPivot); g.add(cabinPivot);
    boomPivot.rotation.z = -0.4;

  } else if (def.id === "crane-k") {
