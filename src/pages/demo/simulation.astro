  } else if (def.id === "bull") {
    // Bulldozer
    [-1, 1].forEach(z => { const t = new THREE.Mesh(new THREE.BoxGeometry(3.8, 0.7, 0.8), dark); t.position.set(0, 0.35, z); g.add(t); });
