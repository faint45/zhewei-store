    // Outriggers
    [-1.4, 1.4].forEach(z => [-1.5, 1.5].forEach(x => {
      const leg = new THREE.Mesh(new THREE.BoxGeometry(0.3, 1, 0.3), grey); leg.position.set(x, 0.5, z); leg.name = "outrigger"; g.add(leg);
    }));
    // Wheels
    [-1.5, 0, 1.5].forEach(x => [-1.1, 1.1].forEach(z => {
      const wh = new THREE.Mesh(new THREE.CylinderGeometry(0.4, 0.4, 0.3, 12), dark); wh.rotation.x = Math.PI/2; wh.position.set(x, 0.4, z); g.add(wh);
    }));
    const boomPivot = new THREE.Group(); boomPivot.name = "boomPivot"; boomPivot.position.set(0.5, 2, 0);
    const boom = new THREE.Mesh(new THREE.BoxGeometry(0.4, 8, 0.4), m(def.color)); boom.position.y = 4; boomPivot.add(boom);
