    const ripper = new THREE.Mesh(new THREE.BoxGeometry(0.3, 1, 0.8), grey); ripper.position.set(2, 0.2, 0); g.add(ripper);

  } else if (def.id === "roller") {
    const body = new THREE.Mesh(new THREE.BoxGeometry(2.5, 1.2, 1.6), m(def.color)); body.position.y = 1.2; g.add(body);
    const drum = new THREE.Mesh(new THREE.CylinderGeometry(0.7, 0.7, 2, 16), grey); drum.rotation.x = Math.PI/2; drum.position.set(-1, 0.7, 0); drum.name = "drum"; g.add(drum);
    const rear = new THREE.Mesh(new THREE.CylinderGeometry(0.5, 0.5, 1.4, 12), dark); rear.rotation.x = Math.PI/2; rear.position.set(1.2, 0.5, 0); g.add(rear);

  } else if (def.id === "bobcat") {
    const body = new THREE.Mesh(new THREE.BoxGeometry(2, 1.2, 1.4), m(def.color)); body.position.y = 0.8; g.add(body);
    [-0.6, 0.6].forEach(z => [-0.6, 0.6].forEach(x => {
      const wh = new THREE.Mesh(new THREE.CylinderGeometry(0.3, 0.3, 0.25, 10), dark); wh.rotation.x = Math.PI/2; wh.position.set(x, 0.3, z); g.add(wh);
    }));
    const armPivot = new THREE.Group(); armPivot.name = "armPivot"; armPivot.position.set(-1, 0.8, 0);
    const arm = new THREE.Mesh(new THREE.BoxGeometry(0.2, 1.5, 1.2), m(def.color)); arm.position.y = 0.75; armPivot.add(arm);
    const bucket = new THREE.Mesh(new THREE.BoxGeometry(0.8, 0.5, 1.2), grey); bucket.position.set(0, 1.5, 0); bucket.name = "bucket"; armPivot.add(bucket);
    g.add(armPivot);

  } else if (def.id === "dump") {
    // Dump truck — high detail
    const bodyMat = mat(def.color);
    // Chassis frame
    const chassis = new THREE.Mesh(new THREE.BoxGeometry(5.5, 0.4, 1.8), frameMat()); chassis.position.y = 0.7; g.add(chassis);
    // Cab
    const cab = new THREE.Mesh(new THREE.BoxGeometry(1.6, 1.5, 1.9), bodyMat); cab.position.set(-1.7, 1.7, 0); g.add(cab);
    const cabRoof = new THREE.Mesh(new THREE.BoxGeometry(1.5, 0.1, 1.85), bodyMat); cabRoof.position.set(-1.7, 2.5, 0); g.add(cabRoof);
    // Windows
    const windshield = new THREE.Mesh(new THREE.PlaneGeometry(1.5, 0.9), glassMat()); windshield.position.set(-0.88, 2, 0); windshield.rotation.y = Math.PI / 2; g.add(windshield);
    [-0.96, 0.96].forEach(z => {
      const sw = new THREE.Mesh(new THREE.PlaneGeometry(1.1, 0.8), glassMat()); sw.position.set(-1.7, 2, z); sw.rotation.y = z > 0 ? 0 : Math.PI; g.add(sw);
    });
    // Headlights
    [-0.6, 0.6].forEach(z => {
      const hl = new THREE.Mesh(new THREE.CylinderGeometry(0.1, 0.1, 0.05, 8), mat(0xffffcc, 0.2, 0.5)); hl.rotation.z = Math.PI / 2; hl.position.set(-2.55, 1.4, z); g.add(hl);
    });
    // Dump bed pivot
    const bedPivot = new THREE.Group(); bedPivot.name = "bedPivot"; bedPivot.position.set(0.5, 0.95, 0);
    const bed = new THREE.Mesh(new THREE.BoxGeometry(3.5, 1.3, 1.85), mat(0x556677, 0.7, 0.2)); bed.position.set(0, 0.65, 0); bedPivot.add(bed);
    // Bed inner
    const bedInner = new THREE.Mesh(new THREE.BoxGeometry(3.3, 0.05, 1.7), mat(0x665544, 0.9)); bedInner.position.set(0, 1.25, 0); bedPivot.add(bedInner);
    // Tailgate
    const tailgate = new THREE.Mesh(new THREE.BoxGeometry(0.1, 1.1, 1.85), mat(0x556677, 0.7, 0.2)); tailgate.position.set(1.8, 0.55, 0); bedPivot.add(tailgate);
    // Hydraulic ram
    addHydraulicCylinder(bedPivot, new THREE.Vector3(-1.5, 0, 0), new THREE.Vector3(-0.5, 1.2, 0));
    g.add(bedPivot);
    // Wheels (dual rear axle)
    addWheel(g, -1.8, 0.45, -1.05); addWheel(g, -1.8, 0.45, 1.05);
    [0.4, 1.4].forEach(x => [-1.05, -0.7, 0.7, 1.05].forEach(z => addWheel(g, x, 0.45, z, 0.42)));
    // Mud flaps
    [1.5].forEach(x => [-1.15, 1.15].forEach(z => {
      const flap = new THREE.Mesh(new THREE.PlaneGeometry(0.5, 0.4), mat(0x222222, 0.95)); flap.position.set(x, 0.2, z); g.add(flap);
