---
import BaseLayout from "../layouts/BaseLayout.astro";
import { products } from "../content/products";
---

<BaseLayout title="免費試用" description="申請築未科技 AI 工具免費試用 — 14 天完整功能體驗。">
  <section class="px-4 py-16">
    <div class="mx-auto max-w-2xl">
      <div class="mb-10 text-center">
        <h1 class="text-4xl font-black">申請免費試用</h1>
        <p class="mt-4 text-lg text-text-muted">填寫以下資訊，我們會在一個工作天內聯繫您開通試用帳號。</p>
      </div>

      <form id="trial-form" class="space-y-5 rounded-2xl border border-border bg-bg-card p-6 md:p-8">
        <!-- Company -->
        <div>
          <label for="company" class="mb-1.5 block text-sm font-semibold text-text-heading">公司名稱 *</label>
          <input
            type="text"
            id="company"
            name="company"
            required
            placeholder="例：大同營造股份有限公司"
            class="w-full rounded-xl border border-border bg-bg px-4 py-3 text-sm text-text placeholder-text-muted/50 outline-none transition-colors focus:border-accent"
          />
        </div>

        <!-- Contact -->
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label for="name" class="mb-1.5 block text-sm font-semibold text-text-heading">聯絡人 *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="您的姓名"
              class="w-full rounded-xl border border-border bg-bg px-4 py-3 text-sm text-text placeholder-text-muted/50 outline-none transition-colors focus:border-accent"
            />
          </div>
          <div>
            <label for="role" class="mb-1.5 block text-sm font-semibold text-text-heading">職稱</label>
            <input
              type="text"
              id="role"
              name="role"
              placeholder="例：工地主任、安衛管理師"
              class="w-full rounded-xl border border-border bg-bg px-4 py-3 text-sm text-text placeholder-text-muted/50 outline-none transition-colors focus:border-accent"
            />
          </div>
        </div>

        <!-- Contact methods -->
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label for="email" class="mb-1.5 block text-sm font-semibold text-text-heading">Email *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="you@company.com"
              class="w-full rounded-xl border border-border bg-bg px-4 py-3 text-sm text-text placeholder-text-muted/50 outline-none transition-colors focus:border-accent"
            />
          </div>
          <div>
            <label for="line" class="mb-1.5 block text-sm font-semibold text-text-heading">LINE ID</label>
            <input
              type="text"
              id="line"
              name="line"
              placeholder="您的 LINE ID"
              class="w-full rounded-xl border border-border bg-bg px-4 py-3 text-sm text-text placeholder-text-muted/50 outline-none transition-colors focus:border-accent"
            />
          </div>
        </div>

        <!-- Product selection -->
        <div>
          <label class="mb-3 block text-sm font-semibold text-text-heading">想試用的套件 *</label>
          <div class="grid gap-3 sm:grid-cols-2">
            {products.map((p) => (
              <label class="flex cursor-pointer items-start gap-3 rounded-xl border border-border bg-bg p-3 transition-colors has-[:checked]:border-accent/50 has-[:checked]:bg-accent/5">
                <input type="checkbox" name="products" value={p.id} class="mt-0.5 accent-accent" />
                <div>
                  <span class="text-sm font-semibold text-text-heading">{p.name}</span>
                  <p class="text-xs text-text-muted">{p.tagline}</p>
                </div>
              </label>
            ))}
          </div>
        </div>

        <!-- Notes -->
        <div>
          <label for="notes" class="mb-1.5 block text-sm font-semibold text-text-heading">補充說明</label>
          <textarea
            id="notes"
            name="notes"
            rows="3"
            placeholder="您目前的痛點、想解決的問題、或任何問題..."
            class="w-full rounded-xl border border-border bg-bg px-4 py-3 text-sm text-text placeholder-text-muted/50 outline-none transition-colors focus:border-accent"
          ></textarea>
        </div>

        <!-- Submit -->
        <button
          type="submit"
          class="w-full rounded-xl bg-accent py-3.5 font-semibold text-white shadow-lg shadow-accent/25 transition-all hover:bg-accent-hover hover:shadow-xl hover:shadow-accent/30"
        >
          送出申請
        </button>
        <p class="text-center text-xs text-text-muted">
          送出即表示您同意我們與您聯繫。我們不會將您的資料分享給第三方。
        </p>
      </form>

      <!-- Success message (hidden by default) -->
      <div id="success-msg" class="hidden rounded-2xl border border-success/30 bg-success/5 p-8 text-center">
        <svg class="mx-auto h-12 w-12 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="mt-4 text-xl font-bold text-success">申請已送出！</h3>
        <p class="mt-2 text-text-muted">我們會在一個工作天內透過 Email 或 LINE 與您聯繫。</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById("trial-form") as HTMLFormElement;
  const successMsg = document.getElementById("success-msg");
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    submitBtn.disabled = true;
    submitBtn.textContent = "送出中…";

    const formData = new FormData(form);
    const data = {
      company: formData.get("company"),
      name: formData.get("name"),
      role: formData.get("role"),
      email: formData.get("email"),
      line: formData.get("line"),
      products: formData.getAll("products"),
      notes: formData.get("notes"),
      timestamp: new Date().toISOString(),
      source: "store.zhe-wei.net",
    };

    try {
      await fetch("https://n8n.zhe-wei.net/webhook/trial-request", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
    } catch {
      // Webhook failure is non-blocking — still show success to user
    }

    // Also send to Telegram as backup notification
    try {
      await fetch("https://cai.zhe-wei.net/api/v1/route", {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: new URLSearchParams({
          text: `#試用申請 ${data.company} / ${data.name} / ${data.email} / ${(data.products as string[]).join(",")}`,
        }),
      });
    } catch {
      // Best-effort
    }

    form.classList.add("hidden");
    successMsg?.classList.remove("hidden");
  });
</script>
