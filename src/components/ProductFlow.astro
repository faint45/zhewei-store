---
interface Step {
  icon: string;
  label: string;
  sublabel: string;
  color: string;
}

interface Props {
  steps: Step[];
  flowId: string;
}

const { steps, flowId } = Astro.props;
---

<div class="relative" id={flowId}>
  <!-- Mobile: vertical stack; Desktop: horizontal -->
  <div class="flex flex-col items-center gap-0 md:flex-row md:justify-center md:gap-0">
    {steps.map((step, i) => (
      <>
        <!-- Step node -->
        <div
          class="flow-step flex flex-col items-center opacity-0 translate-y-4 transition-all duration-500"
          style={`transition-delay: ${i * 150}ms`}
        >
          <div class={`flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br ${step.color} shadow-lg`}>
            <svg class="h-7 w-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={step.icon} />
            </svg>
          </div>
          <div class="mt-2 text-center">
            <div class="text-sm font-semibold text-text-heading">{step.label}</div>
            <div class="text-xs text-text-muted">{step.sublabel}</div>
          </div>
        </div>

        <!-- Arrow between steps -->
        {i < steps.length - 1 && (
          <div
            class="flow-arrow opacity-0 transition-all duration-300 mx-2 my-4 md:my-0"
            style={`transition-delay: ${i * 150 + 100}ms`}
          >
            <!-- Vertical arrow on mobile -->
            <svg class="h-6 w-6 text-accent md:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
            <!-- Horizontal arrow on desktop -->
            <svg class="hidden h-5 w-5 text-accent md:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        )}
      </>
    ))}
  </div>
</div>

<script define:vars={{ flowId }}>
  const container = document.getElementById(flowId);
  if (container) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          container.querySelectorAll('.flow-step, .flow-arrow').forEach((el) => {
            el.classList.remove('opacity-0', 'translate-y-4');
            el.classList.add('opacity-100', 'translate-y-0');
          });
          observer.disconnect();
        }
      },
      { threshold: 0.3 }
    );
    observer.observe(container);
  }
</script>
