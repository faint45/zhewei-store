---
// Animated LINE chat demo showing AI construction bot notifications
---

<div class="line-demo-wrap" id="lineDemo">
  <!-- Phone frame -->
  <div class="phone-frame">
    <div class="phone-screen">
      <!-- LINE header -->
      <div class="line-header">
        <div class="line-avatar">築</div>
        <div>
          <div class="line-name">築未科技 AI 助手</div>
          <div class="line-status">● 線上</div>
        </div>
      </div>

      <!-- Chat messages -->
      <div class="chat-body" id="lineChatBody">
        <!-- Messages injected by JS -->
      </div>
    </div>
  </div>

  <!-- Event triggers on the right -->
  <div class="event-panel">
    <div class="ep-title">觸發事件</div>
    <div class="ep-events" id="epEvents">
      <div class="ep-event" data-index="0">
        <div class="ep-icon ep-photo">📷</div>
        <div>
          <div class="ep-label">工地拍照上傳</div>
          <div class="ep-sub">07:32 工地主任 陳先生</div>
        </div>
      </div>
      <div class="ep-event" data-index="1">
        <div class="ep-icon ep-warn">⚠️</div>
        <div>
          <div class="ep-label">安全缺失偵測</div>
          <div class="ep-sub">AI 辨識風險項目</div>
        </div>
      </div>
      <div class="ep-event" data-index="2">
        <div class="ep-icon ep-report">📋</div>
        <div>
          <div class="ep-label">日報自動生成</div>
          <div class="ep-sub">17:30 定時推播</div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .line-demo-wrap {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 24px;
    align-items: flex-start;
    max-width: 680px;
    margin: 0 auto;
  }
  .phone-frame {
    background: #1a1a2e;
    border-radius: 36px;
    padding: 14px;
    border: 2px solid #333;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5), inset 0 0 0 1px #444;
    position: relative;
  }
  .phone-frame::before {
    content: '';
    display: block;
    width: 80px;
    height: 8px;
    background: #333;
    border-radius: 4px;
    margin: 0 auto 10px;
  }
  .phone-screen {
    background: #0f1117;
    border-radius: 22px;
    overflow: hidden;
    min-height: 360px;
    display: flex;
    flex-direction: column;
  }
  .line-header {
    background: #00b900;
    padding: 10px 12px;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }
  .line-avatar {
    width: 32px;
    height: 32px;
    background: rgba(255,255,255,0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
  }
  .line-name { font-size: 13px; font-weight: 700; color: #fff; }
  .line-status { font-size: 10px; color: rgba(255,255,255,0.8); }
  .chat-body {
    flex: 1;
    padding: 10px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-height: 310px;
  }
  .msg { display: flex; gap: 6px; align-items: flex-end; }
  .msg.bot { flex-direction: row; }
  .msg.user { flex-direction: row-reverse; }
  .msg-av {
    width: 24px;
    height: 24px;
    background: #00b900;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    color: #fff;
    font-weight: 700;
    flex-shrink: 0;
  }
  .msg-bubble {
    max-width: 160px;
    padding: 7px 10px;
    border-radius: 14px;
    font-size: 11px;
    line-height: 1.5;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s, transform 0.3s;
  }
  .msg-bubble.visible { opacity: 1; transform: translateY(0); }
  .msg.bot .msg-bubble { background: #1e2d3d; color: #ddeeff; border-bottom-left-radius: 4px; }
  .msg.user .msg-bubble { background: #00b900; color: #fff; border-bottom-right-radius: 4px; }
  .msg-bubble.alert { background: #2d1a1a; color: #ffaaaa; border: 1px solid #f66; }
  .msg-bubble.success { background: #1a2d1a; color: #aaffaa; border: 1px solid #4a4; }
  .msg-bubble.report { background: #1a2040; color: #aaccff; border: 1px solid #46c; }
  .typing {
    display: flex;
    gap: 3px;
    align-items: center;
    padding: 8px 10px;
    background: #1e2d3d;
    border-radius: 14px;
    border-bottom-left-radius: 4px;
    width: 44px;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .typing.visible { opacity: 1; }
  .typing span {
    width: 5px; height: 5px; background: #6688aa; border-radius: 50%;
    animation: typingBounce 1.2s infinite;
  }
  .typing span:nth-child(2) { animation-delay: 0.2s; }
  .typing span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes typingBounce { 0%,60%,100%{transform:translateY(0)} 30%{transform:translateY(-5px)} }

  .event-panel { display: flex; flex-direction: column; gap: 12px; padding-top: 14px; }
  .ep-title { font-size: 11px; color: #556; text-transform: uppercase; letter-spacing: 1px; }
  .ep-events { display: flex; flex-direction: column; gap: 10px; }
  .ep-event {
    display: flex;
    gap: 10px;
    align-items: center;
    padding: 10px 12px;
    background: #111d2a;
    border-radius: 10px;
    border: 1px solid #243040;
    transition: all .3s;
    opacity: 0.5;
  }
  .ep-event.active { opacity: 1; border-color: #f97316; background: #1a2738; }
  .ep-icon { font-size: 20px; }
  .ep-label { font-size: 12px; color: #ccd; font-weight: 600; }
  .ep-sub { font-size: 10px; color: #556; margin-top: 1px; }

  @media (max-width: 640px) {
    .line-demo-wrap { grid-template-columns: 1fr; }
    .event-panel { display: none; }
  }
</style>

<script>
(function() {
  const MESSAGES = [
    // Sequence 0: photo upload
    { type: 'user', text: '📷 [照片] 3F 北側牆面.jpg', delay: 0 },
    { type: 'typing', delay: 800 },
    { type: 'bot', text: '✅ 照片已收到，AI 分析中…', style: '', delay: 1400 },
    { type: 'bot', text: '⚠️ 偵測到安全缺失：\n樓板開口缺少防護蓋板\n嚴重程度：高', style: 'alert', delay: 2600 },
    { type: 'bot', text: '📍 已自動建立待辦事項\n負責人：陳主任\n期限：今日 16:00', style: '', delay: 3600 },
    // Sequence 1: daily report
    { type: 'bot', text: '📋 17:30 日報已自動生成', style: 'report', delay: 5200 },
    { type: 'bot', text: '今日進度：98.3%\n施工人數：47人\n安全事項：1 項待改善\n\n已傳送給業主 ✓', style: 'report', delay: 6400 },
    // Sequence 2: regulation query
    { type: 'user', text: '鋼筋間距規定？', delay: 8500 },
    { type: 'typing', delay: 9200 },
    { type: 'bot', text: '📖 CNS 560 第 7.3 條：\n主筋間距不得超過柱寬或牆厚之 1.5 倍，且不得超過 450mm', style: 'success', delay: 10100 },
  ];

  function runDemo() {
    const chatBody = document.getElementById('lineChatBody');
    if (!chatBody) return;
    chatBody.innerHTML = '';
    const events = document.querySelectorAll('.ep-event');

    let typingEl: HTMLElement | null = null;

    MESSAGES.forEach((msg, i) => {
      setTimeout(() => {
        // Highlight event panel
        if (msg.type === 'user' && i === 0) events[0]?.classList.add('active');
        if (msg.type === 'bot' && i === 5) { events[1]?.classList.remove('active'); events[2]?.classList.add('active'); }
        if (msg.type === 'user' && i === 7) { events[2]?.classList.remove('active'); }

        if (msg.type === 'typing') {
          const wrap = document.createElement('div');
          wrap.className = 'msg bot';
          wrap.innerHTML = '<div class="msg-av">築</div><div class="typing"><span></span><span></span><span></span></div>';
          chatBody.appendChild(wrap);
          const t = wrap.querySelector('.typing') as HTMLElement;
          setTimeout(() => t.classList.add('visible'), 10);
          typingEl = wrap;
        } else {
          if (typingEl) { typingEl.remove(); typingEl = null; }
          const wrap = document.createElement('div');
          wrap.className = `msg ${msg.type}`;
          const bubble = document.createElement('div');
          bubble.className = `msg-bubble ${msg.style || ''}`;
          bubble.style.whiteSpace = 'pre-line';
          bubble.textContent = msg.text;
          if (msg.type === 'bot') {
            wrap.innerHTML = '<div class="msg-av">築</div>';
            wrap.appendChild(bubble);
          } else {
            wrap.appendChild(bubble);
          }
          chatBody.appendChild(wrap);
          setTimeout(() => bubble.classList.add('visible'), 10);
          chatBody.scrollTop = chatBody.scrollHeight;
        }
      }, msg.delay);
    });

    // Loop after last message
    setTimeout(() => {
      events.forEach(e => e.classList.remove('active'));
      runDemo();
    }, 14000);
  }

  // Start when visible
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { observer.disconnect(); runDemo(); } });
  }, { threshold: 0.4 });
  const el = document.getElementById('lineDemo');
  if (el) observer.observe(el);
})();
</script>
