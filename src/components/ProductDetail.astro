---
import type { Product } from "../content/products";

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<section class="px-4 py-16">
  <div class="mx-auto max-w-4xl">
    <!-- Header -->
    <div class="mb-12">
      <a href="/products" class="mb-4 inline-flex items-center gap-1 text-sm text-text-muted hover:text-accent">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        所有產品
      </a>
      <div class="flex items-start gap-4">
        <div class={`flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br ${product.color}`}>
          <svg class="h-7 w-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={product.icon} />
          </svg>
        </div>
        <div>
          <h1 class="text-3xl font-black md:text-4xl">{product.name}</h1>
          <p class="mt-1 text-lg text-accent">{product.tagline}</p>
        </div>
      </div>
      <p class="mt-6 text-lg leading-relaxed text-text-muted">{product.description}</p>
    </div>

    <!-- Features -->
    <div class="mb-12">
      <h2 class="mb-6 text-2xl font-bold">功能特色</h2>
      <div class="grid gap-3 sm:grid-cols-2">
        {product.features.map((f) => (
          <div class="flex items-start gap-3 rounded-xl border border-border bg-bg-card p-4">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm">{f}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Use Cases -->
    <div class="mb-12">
      <h2 class="mb-6 text-2xl font-bold">應用場景</h2>
      <div class="space-y-4">
        {product.useCases.map((uc, i) => (
          <div class="flex gap-4 rounded-xl border border-border bg-bg-card p-5">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-accent/10 text-sm font-bold text-accent">
              {i + 1}
            </span>
            <p class="text-sm leading-relaxed text-text-muted">{uc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- API Reference -->
    <div class="mb-12">
      <h2 class="mb-6 text-2xl font-bold">API 端點</h2>
      <div class="overflow-hidden rounded-xl border border-border">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border bg-bg-card">
              <th class="px-4 py-3 text-left font-semibold text-text-muted">方法</th>
              <th class="px-4 py-3 text-left font-semibold text-text-muted">端點</th>
              <th class="hidden px-4 py-3 text-left font-semibold text-text-muted sm:table-cell">說明</th>
            </tr>
          </thead>
          <tbody>
            {product.apis.map((api) => (
              <tr class="border-b border-border last:border-0">
                <td class="px-4 py-3">
                  <span class:list={[
                    "rounded px-2 py-0.5 text-xs font-bold",
                    api.method === "GET" ? "bg-green-500/10 text-green-400" : "bg-blue-500/10 text-blue-400",
                  ]}>
                    {api.method}
                  </span>
                </td>
                <td class="px-4 py-3 font-mono text-xs text-text">{api.path}</td>
                <td class="hidden px-4 py-3 text-text-muted sm:table-cell">{api.desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Interactive Demo Slot -->
    <slot name="demo" />

    <!-- Pricing hint + CTA -->
    <div class="rounded-2xl border border-accent/20 bg-gradient-to-br from-accent/5 to-amber-500/5 p-8 text-center">
      {product.comingSoonPrice && (
        <p class="mb-2 text-sm text-text-muted">預計定價</p>
        <p class="text-2xl font-bold text-accent">{product.comingSoonPrice}</p>
      )}
      <p class="mt-3 text-text-muted">現在申請試用，搶先體驗完整功能。</p>
      <div class="mt-5 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="/demo" class="inline-flex rounded-xl bg-accent px-6 py-3 font-semibold text-white hover:bg-accent-hover">
          免費申請試用
        </a>
        <a href="/pricing" class="inline-flex rounded-xl border border-border px-6 py-3 font-semibold text-text hover:border-accent/30 hover:bg-bg-card">
          查看完整定價
        </a>
      </div>
    </div>
  </div>
</section>
