---

---

<section class="relative overflow-hidden px-4 pb-16 pt-20 md:pb-24 md:pt-32">
  <!-- Particle background -->
  <div id="hero-particles" class="pointer-events-none absolute inset-0"></div>
  <!-- Background glow -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="absolute left-1/2 top-0 h-[500px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-accent/5 blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-4xl text-center">
    <div data-aos="fade-down" data-aos-delay="100" class="mb-6 inline-flex items-center gap-2 rounded-full border border-accent/20 bg-accent/5 px-4 py-1.5 text-sm text-accent">
      <span class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
      台灣營建業 + 防災科技 AI 平台
    </div>

    <h1 data-aos="fade-up" data-aos-delay="200" class="text-3xl font-black leading-tight tracking-tight sm:text-4xl md:text-6xl">
      <span class="text-text-heading">營建科技化</span>
      <br class="sm:hidden" />
      <span class="mx-1 text-text-muted sm:mx-2">×</span>
      <span class="bg-gradient-to-r from-accent to-amber-400 bg-clip-text text-transparent">
        科技防災
      </span>
    </h1>

    <p data-aos="fade-up" data-aos-delay="300" class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-text-muted sm:mt-6 sm:text-lg md:text-xl">
      7 大 AI 引擎 — 從文件解析到 VR 訓練，從工地監理到颱風預警。
      <br class="hidden md:block" />
      台灣唯一整合營建施工 + 防災預警的 AI 平台。
    </p>

    <div data-aos="fade-up" data-aos-delay="400" class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a href="/demo" class="inline-flex items-center gap-2 rounded-xl bg-accent px-6 py-3 font-semibold text-white shadow-lg shadow-accent/25 transition-all hover:bg-accent-hover hover:shadow-xl hover:shadow-accent/30">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        免費申請試用
      </a>
      <a href="/products" class="inline-flex items-center gap-2 rounded-xl border border-border bg-bg-card px-6 py-3 font-semibold text-text transition-colors hover:border-accent/30 hover:bg-bg-card-hover">
        瀏覽產品
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
    </div>

    <!-- Stats with animated counters -->
    <div id="stats-block" data-aos="fade-up" data-aos-delay="500" class="mx-auto mt-10 grid max-w-2xl grid-cols-3 gap-4 sm:mt-16 sm:gap-8">
      <div>
        <div class="text-3xl font-black text-text-heading" data-count="7" data-suffix="">0</div>
        <div class="mt-1 text-sm text-text-muted">AI 產品</div>
      </div>
      <div>
        <div class="text-3xl font-black text-text-heading" data-count="40" data-suffix="+">0</div>
        <div class="mt-1 text-sm text-text-muted">API 端點</div>
      </div>
      <div>
        <div class="text-3xl font-black text-text-heading" data-count="59" data-suffix="">0</div>
        <div class="mt-1 text-sm text-text-muted">微服務容器</div>
      </div>
    </div>
  </div>
</section>

<script>
  function animateCounter(el: HTMLElement) {
    const target = parseInt(el.dataset.count || "0");
    const suffix = el.dataset.suffix || "";
    const duration = 1200;
    const start = performance.now();

    function update(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      // ease-out cubic
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.floor(eased * target) + suffix;
      if (progress < 1) requestAnimationFrame(update);
    }
    requestAnimationFrame(update);
  }

  const statsBlock = document.getElementById("stats-block");
  if (statsBlock) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            statsBlock.querySelectorAll("[data-count]").forEach((el) => {
              animateCounter(el as HTMLElement);
            });
            observer.disconnect();
          }
        });
      },
      { threshold: 0.5 }
    );
    observer.observe(statsBlock);
  }

  // tsParticles — lightweight network particle effect
  (async () => {
    // @ts-ignore
    const { tsParticles } = await import("https://cdn.jsdelivr.net/npm/@tsparticles/engine@3.7.1/+esm");
    const { loadSlim } = await import("https://cdn.jsdelivr.net/npm/@tsparticles/slim@3.7.1/+esm");
    await loadSlim(tsParticles);
    await tsParticles.load({
      id: "hero-particles",
      options: {
        fullScreen: false,
        background: { color: "transparent" },
        fpsLimit: 60,
        particles: {
          number: { value: 40, density: { enable: true, width: 1200, height: 800 } },
          color: { value: ["#f97316", "#fb923c", "#fbbf24", "#60a5fa"] },
          shape: { type: "circle" },
          opacity: { value: { min: 0.1, max: 0.4 } },
          size: { value: { min: 1, max: 3 } },
          links: {
            enable: true,
            distance: 150,
            color: "#f97316",
            opacity: 0.12,
            width: 1,
          },
          move: {
            enable: true,
            speed: 0.6,
            direction: "none",
            outModes: { default: "bounce" },
          },
        },
        interactivity: {
          events: {
            onHover: { enable: true, mode: "grab" },
          },
          modes: {
            grab: { distance: 140, links: { opacity: 0.3 } },
          },
        },
        detectRetina: true,
      },
    });
  })();
</script>
