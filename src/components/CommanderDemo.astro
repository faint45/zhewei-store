---
// Animated Commander 5-Agent decision demo
---

<div class="cmd-wrap" id="cmdDemo">
  <div class="cmd-left">
    <div class="cmd-header">
      <div class="cmd-avatar">🧠</div>
      <div>
        <div class="cmd-title">AI Commander 指揮官</div>
        <div class="cmd-status" id="cmdStatus">● 待命</div>
      </div>
    </div>
    <!-- Input panel -->
    <div class="cmd-input" id="cmdInput">
      <div class="cmd-input-row"><span class="cmd-label">天氣</span><span id="cmdWeather" class="cmd-val">-</span></div>
      <div class="cmd-input-row"><span class="cmd-label">風速</span><span id="cmdWind" class="cmd-val">-</span></div>
      <div class="cmd-input-row"><span class="cmd-label">結構偏差</span><span id="cmdDev" class="cmd-val">-</span></div>
      <div class="cmd-input-row"><span class="cmd-label">安全係數</span><span id="cmdSF" class="cmd-val">-</span></div>
    </div>
    <!-- Final decision -->
    <div class="cmd-decision" id="cmdDecision" style="opacity:0">
      <div class="cmd-decision-label">最終指令</div>
      <div class="cmd-decision-text" id="cmdAction">-</div>
      <div class="cmd-decision-score" id="cmdScore">-</div>
    </div>
  </div>
  <div class="cmd-right">
    <div class="cmd-agents-title">5-Agent 並行分析</div>
    <div class="cmd-agents" id="cmdAgents">
      <div class="cmd-agent" data-agent="0"><div class="cmd-agent-icon">👁</div><div class="cmd-agent-name">Vision</div><div class="cmd-agent-bar"><div class="cmd-bar-fill"></div></div><div class="cmd-agent-val">-</div></div>
      <div class="cmd-agent" data-agent="1"><div class="cmd-agent-icon">🌤</div><div class="cmd-agent-name">Weather</div><div class="cmd-agent-bar"><div class="cmd-bar-fill"></div></div><div class="cmd-agent-val">-</div></div>
      <div class="cmd-agent" data-agent="2"><div class="cmd-agent-icon">🏗</div><div class="cmd-agent-name">Structural</div><div class="cmd-agent-bar"><div class="cmd-bar-fill"></div></div><div class="cmd-agent-val">-</div></div>
      <div class="cmd-agent" data-agent="3"><div class="cmd-agent-icon">📋</div><div class="cmd-agent-name">Action</div><div class="cmd-agent-bar"><div class="cmd-bar-fill"></div></div><div class="cmd-agent-val">-</div></div>
      <div class="cmd-agent" data-agent="4"><div class="cmd-agent-icon">⚖️</div><div class="cmd-agent-name">Supervisor</div><div class="cmd-agent-bar"><div class="cmd-bar-fill"></div></div><div class="cmd-agent-val">-</div></div>
    </div>
    <div class="cmd-formula" id="cmdFormula" style="opacity:0">
      Score = 0.6×Rule + 0.25×RAG + 0.15×AI
    </div>
  </div>
</div>

<style>
  .cmd-wrap { display:grid; grid-template-columns:1fr 1fr; gap:16px; max-width:760px; margin:0 auto; }
  .cmd-left, .cmd-right { background:#0d1117; border-radius:10px; border:1px solid #30363d; overflow:hidden; }
  .cmd-header { display:flex; align-items:center; gap:10px; padding:10px 14px; background:#161b22; border-bottom:1px solid #30363d; }
  .cmd-avatar { font-size:20px; }
  .cmd-title { font-size:12px; font-weight:700; color:#e6edf3; }
  .cmd-status { font-size:9px; color:#3fb950; }
  .cmd-input { padding:12px; display:flex; flex-direction:column; gap:6px; }
  .cmd-input-row { display:flex; justify-content:space-between; font-size:11px; }
  .cmd-label { color:#6e7681; }
  .cmd-val { color:#c9d1d9; font-family:monospace; transition:color .3s; }
  .cmd-val.warn { color:#f0883e; }
  .cmd-val.danger { color:#f85149; }
  .cmd-val.ok { color:#3fb950; }
  .cmd-decision { padding:12px; margin:8px 12px 12px; border-radius:8px; background:#1a1a2e; border-left:3px solid #f97316; transition:opacity .5s; }
  .cmd-decision-label { font-size:9px; color:#f97316; font-weight:700; text-transform:uppercase; letter-spacing:1px; }
  .cmd-decision-text { font-size:12px; color:#e6edf3; font-weight:600; margin-top:4px; line-height:1.5; }
  .cmd-decision-score { font-size:10px; color:#6e7681; margin-top:4px; font-family:monospace; }
  .cmd-right { padding:12px; display:flex; flex-direction:column; gap:8px; }
  .cmd-agents-title { font-size:11px; font-weight:700; color:#8b949e; text-transform:uppercase; letter-spacing:1px; }
  .cmd-agents { display:flex; flex-direction:column; gap:8px; }
  .cmd-agent { display:grid; grid-template-columns:24px 70px 1fr 40px; align-items:center; gap:6px; }
  .cmd-agent-icon { font-size:14px; }
  .cmd-agent-name { font-size:10px; color:#8b949e; }
  .cmd-agent-bar { height:8px; background:#21262d; border-radius:4px; overflow:hidden; }
  .cmd-bar-fill { height:100%; width:0%; border-radius:4px; transition:width .8s cubic-bezier(.4,0,.2,1), background .3s; background:#3fb950; }
  .cmd-bar-fill.warn { background:#f0883e; }
  .cmd-bar-fill.danger { background:#f85149; }
  .cmd-agent-val { font-size:10px; color:#6e7681; font-family:monospace; text-align:right; }
  .cmd-formula { font-size:9px; color:#6e7681; font-family:monospace; text-align:center; padding:8px; border-top:1px solid #21262d; margin-top:auto; transition:opacity .5s; }
  @media(max-width:640px) { .cmd-wrap { grid-template-columns:1fr; } }
</style>

<script>
(function(){
  const SCENARIOS = [
    { weather:"短暫陣雨", wind:"12 m/s", dev:"4.5 cm", sf:"1.3", windClass:"warn", devClass:"warn", sfClass:"warn",
      agents:[0.12, 0.62, 0.48, 0.35, 0.55], action:"暫停吊裝作業，加強梁端監測", score:0.485, priority:"HIGH" },
    { weather:"晴天", wind:"3 m/s", dev:"1.2 cm", sf:"1.8", windClass:"ok", devClass:"ok", sfClass:"ok",
      agents:[0.05, 0.10, 0.08, 0.20, 0.12], action:"施工正常，持續監控", score:0.112, priority:"LOW" },
    { weather:"豪雨特報", wind:"18 m/s", dev:"8.3 cm", sf:"1.1", windClass:"danger", devClass:"danger", sfClass:"danger",
      agents:[0.75, 0.92, 0.85, 0.60, 0.88], action:"立即停工！撤離高處人員，加固臨時支撐", score:0.842, priority:"CRITICAL" },
  ];
  let idx = 0;

  function run() {
    const s = SCENARIOS[idx % SCENARIOS.length]; idx++;
    const statusEl = document.getElementById("cmdStatus") as HTMLElement;
    const decisionEl = document.getElementById("cmdDecision") as HTMLElement;
    const formulaEl = document.getElementById("cmdFormula") as HTMLElement;
    if (!statusEl) return;

    // Reset
    decisionEl.style.opacity = "0";
    formulaEl.style.opacity = "0";
    document.querySelectorAll(".cmd-bar-fill").forEach(b => { (b as HTMLElement).style.width = "0%"; b.className = "cmd-bar-fill"; });
    document.querySelectorAll(".cmd-agent-val").forEach(v => v.textContent = "-");
    statusEl.textContent = "● 分析中…"; statusEl.style.color = "#f0883e";

    // Animate inputs
    setTimeout(() => {
      (document.getElementById("cmdWeather") as HTMLElement).textContent = s.weather;
      const windEl = document.getElementById("cmdWind") as HTMLElement; windEl.textContent = s.wind; windEl.className = `cmd-val ${s.windClass}`;
      const devEl = document.getElementById("cmdDev") as HTMLElement; devEl.textContent = s.dev; devEl.className = `cmd-val ${s.devClass}`;
      const sfEl = document.getElementById("cmdSF") as HTMLElement; sfEl.textContent = s.sf; sfEl.className = `cmd-val ${s.sfClass}`;
    }, 300);

    // Animate agents one by one
    s.agents.forEach((val, i) => {
      setTimeout(() => {
        const bar = document.querySelectorAll(".cmd-bar-fill")[i] as HTMLElement;
        bar.style.width = `${val * 100}%`;
        bar.className = `cmd-bar-fill ${val > 0.7 ? "danger" : val > 0.4 ? "warn" : ""}`;
        document.querySelectorAll(".cmd-agent-val")[i].textContent = val.toFixed(2);
      }, 800 + i * 400);
    });

    // Show formula
    setTimeout(() => { formulaEl.style.opacity = "1"; }, 2800);

    // Show decision
    setTimeout(() => {
      decisionEl.style.opacity = "1";
      decisionEl.style.borderColor = s.score > 0.7 ? "#f85149" : s.score > 0.4 ? "#f0883e" : "#3fb950";
      (document.getElementById("cmdAction") as HTMLElement).textContent = s.action;
      (document.getElementById("cmdScore") as HTMLElement).textContent = `Final Score: ${s.score.toFixed(3)} | Priority: ${s.priority}`;
      statusEl.textContent = "● 決策完成"; statusEl.style.color = "#3fb950";
    }, 3500);

    setTimeout(run, 8000);
  }

  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { obs.disconnect(); run(); } });
  }, { threshold: 0.3 });
  const el = document.getElementById("cmdDemo");
  if (el) obs.observe(el);
})();
</script>
